sswork and property risk.\n- Joining the inline security profile dataset to a documented app mart API preserves v2.0 compatibility where it exists while keeping the view genuinely centered on the requested class.\n\n## Open Questions\n(none)\n\n## Next Steps\n(none)\n\n## References\n(none)\n\n## Time Scope\n\n'}, {'role': 'system', 'content': 'You are a top-tier summarization engine. Your task is to summarize text and make it versatile.\nBe brief and concise, but keep the important information and the subject.\nUse synonym words where possible in order to change the wording but keep the meaning.\n'}], 'model': 'amazon.nova-lite-v1:0', 'custom_llm_provider': 'bedrock', 'drop_params': True, 'max_completion_tokens': 10000, 'stream': False, 'aws_access_key_id': 'ASIA47CRUNE7JUKXLJJV', 'aws_secret_access_key': 'i1R4BvW3uk2adinZkRsr2TKyPcmnD+sFeL2/LOaQ', 'aws_session_token': '', 'aws_region_name': 'us-east-1', 'response_format': {'type': 'json_schema', 'json_schema': {'name': 'SummarizedContent', 'schema': {'description': 'Class for a single class label summary and description.', 'properties': {'summary': {'title': 'Summary', 'type': 'string'}, 'description': {'title': 'Description', 'type': 'string'}}, 'required': ['summary', 'description'], 'title': 'SummarizedContent', 'type': 'object'}}}}
